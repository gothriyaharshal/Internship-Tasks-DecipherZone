class Animal {
    void eat() {
        System.out.println("Animal eats");
    }
}

class Dog extends Animal {
    void bark() {
        System.out.println("Dog barks");
    }
}

// Generic class
class Box<T extends Animal> {
    T obj;

    Box(T obj) {
        this.obj = obj;
    }

    void show() {
        obj.eat(); // allowed because T is Animal or subclass
    }
}

public class Main {
    public static void main(String[] args) {

        Dog d = new Dog();

        Box<Dog> box = new Box<>(d);
        box.show();
    }
}

